version: '3.8'

services:
  snipeit:
    image: snipe/snipe-it:latest
    container_name: snipeit
    restart: unless-stopped
    environment:
      APP_ENV: production
      APP_DEBUG: "false"
      APP_KEY: {{ snipeit_app_key }}
      APP_URL: https://{{ domain_assets }}
      APP_TIMEZONE: "Europe/Prague"
      APP_LOCALE: "en"
      APP_FORCE_TLS: "true"
      DB_CONNECTION: mysql
      DB_HOST: snipeit_db
      DB_DATABASE: {{ snipeit_mysql_database }}
      DB_USERNAME: {{ snipeit_mysql_user }}
      DB_PASSWORD: {{ snipeit_mysql_password }}
      LOGIN_WITH_DEFAULT_USER: "false"
      SESSION_SECURE_COOKIE: "true"
      TRUSTED_PROXIES: "*"
      APP_DISABLE_SETUP: "true"
    ports:
      - "80"
    depends_on:
      snipeit_db:
        condition: service_healthy
    networks:
      - {{ docker_network }}

  snipeit_db:
    image: mysql:8.0
    container_name: snipeit_db
    restart: unless-stopped
    command: --default-authentication-plugin=mysql_native_password
    environment:
      MYSQL_DATABASE: {{ snipeit_mysql_database }}
      MYSQL_USER: {{ snipeit_mysql_user }}
      MYSQL_PASSWORD: {{ snipeit_mysql_password }}
      MYSQL_ROOT_PASSWORD: {{ snipeit_mysql_root_password }}
    volumes:
      - snipeit_db_data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-u", "root", "-p{{ snipeit_mysql_root_password }}"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 1G
    networks:
      - {{ docker_network }}

volumes:
  snipeit_db_data:

networks:
  {{ docker_network }}:
    external: true
